{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://goeasy-backend.onrender.com/api/:path*"
    },   
    {
      "source": "/auth/:path*",
      "destination": "https://goeasy-backend.onrender.com/auth/:path*"
    },   
    {
      "source": "/:path*",
      "destination": "/"
    }
  ]
}